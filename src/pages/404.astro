---
// 404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — heisenshark" description="Page not found">
  <div class="not-found">
    <div class="nf-content">
      <div class="nf-code text-mono gradient-text">404</div>
      <h1>Page Not Found</h1>
      <p>Looks like this page doesn't exist — or I deleted it by accident.</p>
      <div class="nf-terminal glass-card">
        <span class="t-prompt text-mono">$</span>
        <span class="t-cmd text-mono"> find / -name "this-page" 2&gt;/dev/null</span>
        <br/>
        <span class="t-output text-mono text-muted">find: no results found.</span>
      </div>
      <a href="/" class="btn btn-primary" style="margin-top: 2rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to Home
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .nf-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    animation: fadeInUp 0.6s ease;
  }

  .nf-code {
    font-size: 8rem;
    font-weight: 900;
    line-height: 1;
    opacity: 0.8;
  }

  .nf-content h1 {
    font-size: 2rem;
  }

  .nf-content > p {
    color: var(--text-secondary);
  }

  .nf-terminal {
    padding: 1.25rem 2rem;
    text-align: left;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .t-prompt { color: var(--accent-green); }
  .t-cmd { color: var(--text-primary); }
  .t-output { display: block; margin-top: 0.5rem; padding-left: 1.25rem; }
</style>
