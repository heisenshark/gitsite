---
// Hero.astro — Full-viewport hero with canvas fireworks and typing animation
---

<section class="hero" id="hero" aria-label="Hero section">
  <!-- Fireworks Canvas -->
  <canvas id="fireworks-canvas" aria-hidden="true"></canvas>

  <!-- Floating Orbs (CSS decoration) -->
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>
  <div class="orb orb-3" aria-hidden="true"></div>

  <!-- Grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="hero-content">
    <!-- Terminal prompt badge -->
    <div class="hero-prompt" aria-hidden="true">
      <span class="prompt-prefix">user@arch</span>
      <span class="prompt-path">:~$</span>
      <span class="prompt-cmd"> whoami</span>
    </div>

    <!-- Main heading -->
    <h1 class="hero-title">
      <span class="hero-greeting">Hi, I'm</span>
      <span class="hero-name gradient-text">heisenshark</span>
    </h1>

    <!-- Typing subtitle -->
    <div class="hero-subtitle" aria-label="I am a software developer interested in technology">
      <span class="typing-prefix">I </span>
      <span class="typing-text" id="typing-text" aria-live="polite"></span>
      <span class="typing-cursor" aria-hidden="true">|</span>
    </div>

    <!-- Description -->
    <p class="hero-desc">
      A passionate coder who loves breaking things, printing them in 3D,
      solving cubes at speed, and running Linux on everything.
      Welcome to my corner of the internet.
    </p>

    <!-- CTA Buttons -->
    <div class="hero-actions">
      <a href="/projects" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        View Projects
      </a>
      <a href="/blog" class="btn btn-outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Read Blog
      </a>
      <a href="/contact" class="btn btn-outline" style="border-color: rgba(255,0,204,0.4); color: var(--accent-magenta);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Get in Touch
      </a>
    </div>

    <!-- Interest badges -->
    <div class="hero-badges" aria-label="Interests">
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        Linux
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        3D Printing
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        3D Modeling
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Speedcubing
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        Coding
      </span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>scroll</span>
  </div>
</section>

<script>
  // =============================================
  // FIREWORKS CANVAS ENGINE
  // =============================================
  const canvas = document.getElementById('fireworks-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  let W = window.innerWidth;
  let H = window.innerHeight;
  canvas.width = W;
  canvas.height = H;

  window.addEventListener('resize', () => {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  });

  // Colors matching the design system
  const COLORS = [
    '#00e5ff', '#ff00cc', '#39ff14', '#8b5cf6', '#ff6b35',
    '#00bfff', '#ff69b4', '#7fff00', '#da70d6', '#ffa500'
  ];

  // Particle class
  class Particle {
    x: number; y: number;
    vx: number; vy: number;
    alpha: number; color: string;
    size: number; decay: number; gravity: number;
    tail: { x: number; y: number }[];

    constructor(x: number, y: number, color: string) {
      this.x = x; this.y = y;
      this.color = color;
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 5 + 1.5;
      this.vx = Math.cos(angle) * speed;
      this.vy = Math.sin(angle) * speed;
      this.alpha = 1;
      this.size = Math.random() * 2.5 + 1;
      this.decay = Math.random() * 0.012 + 0.008;
      this.gravity = 0.08;
      this.tail = [];
    }

    update() {
      this.tail.push({ x: this.x, y: this.y });
      if (this.tail.length > 6) this.tail.shift();
      this.x += this.vx;
      this.y += this.vy;
      this.vy += this.gravity;
      this.vx *= 0.98;
      this.alpha -= this.decay;
    }

    draw(ctx: CanvasRenderingContext2D) {
      // Draw tail
      for (let i = 0; i < this.tail.length; i++) {
        const t = this.tail[i];
        const ratio = i / this.tail.length;
        ctx.globalAlpha = this.alpha * ratio * 0.4;
        ctx.fillStyle = this.color;
        ctx.beginPath();
        ctx.arc(t.x, t.y, this.size * ratio * 0.6, 0, Math.PI * 2);
        ctx.fill();
      }
      // Draw particle
      ctx.globalAlpha = this.alpha;
      ctx.shadowBlur = 8;
      ctx.shadowColor = this.color;
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    isDead() { return this.alpha <= 0; }
  }

  // Rocket class
  class Rocket {
    x: number; y: number;
    vx: number; vy: number;
    color: string; targetY: number;
    trail: { x: number; y: number; alpha: number }[];

    constructor() {
      this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
      this.x = W * 0.2 + Math.random() * W * 0.6;
      this.y = H;
      this.targetY = H * 0.15 + Math.random() * H * 0.45;
      this.vx = (Math.random() - 0.5) * 2;
      this.vy = -(Math.random() * 5 + 10);
      this.trail = [];
    }

    update() {
      this.trail.push({ x: this.x, y: this.y, alpha: 1 });
      if (this.trail.length > 12) this.trail.shift();
      this.trail.forEach(t => t.alpha -= 0.08);
      this.x += this.vx;
      this.y += this.vy;
      this.vy += 0.22; // gravity slowing
    }

    draw(ctx: CanvasRenderingContext2D) {
      for (const t of this.trail) {
        if (t.alpha <= 0) continue;
        ctx.globalAlpha = Math.max(0, t.alpha * 0.6);
        ctx.fillStyle = this.color;
        ctx.shadowBlur = 6;
        ctx.shadowColor = this.color;
        ctx.beginPath();
        ctx.arc(t.x, t.y, 1.5, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.shadowBlur = 0;
      ctx.globalAlpha = 1;
      ctx.fillStyle = '#ffffff';
      ctx.shadowBlur = 12;
      ctx.shadowColor = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, 2.5, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    shouldExplode() { return this.vy >= -2; }
  }

  // Burst: circular ring wave
  class Ring {
    x: number; y: number; r: number;
    alpha: number; color: string; maxR: number;

    constructor(x: number, y: number, color: string) {
      this.x = x; this.y = y;
      this.r = 0; this.maxR = 60 + Math.random() * 40;
      this.alpha = 0.8; this.color = color;
    }

    update() {
      this.r += 3;
      this.alpha -= 0.03;
    }

    draw(ctx: CanvasRenderingContext2D) {
      if (this.alpha <= 0) return;
      ctx.globalAlpha = this.alpha;
      ctx.strokeStyle = this.color;
      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 10;
      ctx.shadowColor = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
      ctx.stroke();
      ctx.shadowBlur = 0;
    }

    isDead() { return this.alpha <= 0 || this.r >= this.maxR; }
  }

  // Stars background
  const stars: { x: number; y: number; r: number; alpha: number; pulse: number }[] = [];
  for (let i = 0; i < 120; i++) {
    stars.push({
      x: Math.random() * W,
      y: Math.random() * H,
      r: Math.random() * 1.2 + 0.2,
      alpha: Math.random() * 0.5 + 0.1,
      pulse: Math.random() * Math.PI * 2,
    });
  }

  function drawStars(t: number) {
    for (const s of stars) {
      s.pulse += 0.005;
      const a = s.alpha + Math.sin(s.pulse) * 0.15;
      ctx.globalAlpha = Math.max(0, Math.min(1, a));
      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  // State
  const particles: Particle[] = [];
  const rockets: Rocket[] = [];
  const rings: Ring[] = [];
  let lastRocketTime = 0;
  let animFrame: number;
  let tick = 0;

  function explode(x: number, y: number) {
    const color = COLORS[Math.floor(Math.random() * COLORS.length)];
    const color2 = COLORS[Math.floor(Math.random() * COLORS.length)];
    const count = 80 + Math.floor(Math.random() * 60);

    for (let i = 0; i < count; i++) {
      particles.push(new Particle(x, y, i % 3 === 0 ? color2 : color));
    }
    rings.push(new Ring(x, y, color));
    rings.push(new Ring(x, y, color2));
  }

  function loop(timestamp: number) {
    animFrame = requestAnimationFrame(loop);
    tick++;

    // Clear with fade trail effect
    ctx.globalAlpha = 0.18;
    ctx.fillStyle = '#07071a';
    ctx.fillRect(0, 0, W, H);

    // Stars
    drawStars(tick);

    // Launch rockets on schedule
    if (timestamp - lastRocketTime > 1200 + Math.random() * 800) {
      rockets.push(new Rocket());
      lastRocketTime = timestamp;
    }

    // Update & draw rings
    for (let i = rings.length - 1; i >= 0; i--) {
      rings[i].update();
      rings[i].draw(ctx);
      if (rings[i].isDead()) rings.splice(i, 1);
    }

    // Update & draw rockets
    for (let i = rockets.length - 1; i >= 0; i--) {
      rockets[i].update();
      rockets[i].draw(ctx);
      if (rockets[i].shouldExplode()) {
        explode(rockets[i].x, rockets[i].y);
        rockets.splice(i, 1);
      }
    }

    // Update & draw particles
    for (let i = particles.length - 1; i >= 0; i--) {
      particles[i].update();
      particles[i].draw(ctx);
      if (particles[i].isDead()) particles.splice(i, 1);
    }

    ctx.globalAlpha = 1;
  }

  // Start after a short delay
  setTimeout(() => {
    loop(0);
    // Initial burst
    explode(W * 0.3, H * 0.35);
    explode(W * 0.7, H * 0.4);
  }, 300);

  // Click/tap to launch fireworks
  canvas.addEventListener('click', (e) => {
    const color = COLORS[Math.floor(Math.random() * COLORS.length)];
    explode(e.clientX, e.clientY);
  });

  // Pause when not visible
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      cancelAnimationFrame(animFrame);
    } else {
      loop(0);
    }
  });

  // =============================================
  // TYPING ANIMATION
  // =============================================
  const phrases = [
    'write C++ at 3AM ☕',
    'print things in 3D 🖨️',
    'solve cubes sub-15 🎲',
    'model in Blender 🧊',
    'rice my Linux setup 🐧',
    'break stuff and learn 🔧',
    'automate everything 🤖',
    'run Arch, btw 👾',
  ];

  const typingEl = document.getElementById('typing-text')!;
  let phraseIdx = 0;
  let charIdx = 0;
  let deleting = false;
  let pause = 0;

  function typeLoop() {
    const phrase = phrases[phraseIdx];

    if (!deleting) {
      typingEl.textContent = phrase.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx >= phrase.length) {
        deleting = true;
        pause = 60;
      }
    } else {
      if (pause > 0) { pause--; }
      else {
        typingEl.textContent = phrase.slice(0, charIdx - 1);
        charIdx--;
        if (charIdx <= 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
        }
      }
    }

    const delay = deleting && pause <= 0 ? 50 : deleting ? 100 : 80;
    setTimeout(typeLoop, delay);
  }

  typeLoop();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--gradient-hero);
  }

  #fireworks-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    cursor: crosshair;
  }

  /* Floating Orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    z-index: 1;
    animation: float 6s ease-in-out infinite;
  }

  .orb-1 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.12) 0%, transparent 70%);
    top: -10%; left: -10%;
    animation-duration: 7s;
  }

  .orb-2 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(255, 0, 204, 0.1) 0%, transparent 70%);
    bottom: -5%; right: -5%;
    animation-duration: 9s;
    animation-delay: -3s;
  }

  .orb-3 {
    width: 250px; height: 250px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
    top: 40%; left: 60%;
    animation-duration: 11s;
    animation-delay: -6s;
  }

  /* Grid overlay */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 1;
    pointer-events: none;
    mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.6) 0%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 2rem 1.5rem;
    max-width: 900px;
    animation: fadeInUp 0.8s ease both;
  }

  /* Terminal prompt */
  .hero-prompt {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border-subtle);
    border-radius: 9999px;
    padding: 0.35rem 1rem;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
  }

  .prompt-prefix { color: var(--accent-green); font-weight: 600; }
  .prompt-path { color: var(--accent-cyan); }
  .prompt-cmd { color: var(--text-secondary); }

  /* Title */
  .hero-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .hero-greeting {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 400;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  /* Typing */
  .hero-subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 500;
    margin-bottom: 1.5rem;
    min-height: 2.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .typing-prefix {
    color: var(--text-secondary);
  }

  .typing-text {
    color: var(--text-primary);
    font-weight: 600;
  }

  .typing-cursor {
    color: var(--accent-magenta);
    font-weight: 100;
    animation: blink 0.9s step-end infinite;
    font-size: 1.4em;
    line-height: 1;
  }

  /* Description */
  .hero-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 2rem;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  /* Interest badges */
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .interest-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    transition: all var(--transition-fast);
    cursor: default;
  }

  .interest-badge:hover {
    color: var(--accent-cyan);
    border-color: var(--border-accent);
    background: rgba(0, 229, 255, 0.06);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
    animation: fadeIn 1.5s ease 1s both;
  }

  .scroll-line {
    width: 1.5px;
    height: 40px;
    background: linear-gradient(to bottom, var(--accent-cyan), transparent);
    animation: float 2s ease-in-out infinite;
  }

  .scroll-indicator span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .hero-actions { flex-direction: column; align-items: center; }
    .btn { width: 100%; max-width: 280px; justify-content: center; }
  }
</style>
