---
// Hero.astro — Full-viewport hero with Three.js 3D room scene
import RoomScene from './RoomScene.astro';
---

<section class="hero" id="hero" aria-label="Hero section">
  <!-- 3D Room fills the background -->
  <div class="hero-3d-bg">
    <RoomScene />
  </div>

  <!-- Text content overlay -->
  <div class="hero-content">
    <!-- Terminal prompt badge -->
    <div class="hero-prompt" aria-hidden="true">
      <span class="prompt-prefix">user@arch</span>
      <span class="prompt-path">:~$</span>
      <span class="prompt-cmd"> whoami</span>
    </div>

    <!-- Main heading -->
    <h1 class="hero-title">
      <span class="hero-greeting">Hi, I'm</span>
      <span class="hero-name gradient-text">heisenshark</span>
    </h1>

    <!-- Typing subtitle -->
    <div class="hero-subtitle" aria-label="I am a software developer interested in technology">
      <span class="typing-prefix">I </span>
      <span class="typing-text" id="typing-text" aria-live="polite"></span>
      <span class="typing-cursor" aria-hidden="true">|</span>
    </div>

    <!-- Description -->
    <p class="hero-desc">
      A passionate coder who loves breaking things, printing them in 3D,
      solving cubes at speed, and running Linux on everything.
      <em>Click around the room to explore.</em>
    </p>

    <!-- CTA Buttons -->
    <div class="hero-actions">
      <a href="/projects" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        View Projects
      </a>
      <a href="/blog" class="btn btn-outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        Read Blog
      </a>
      <a href="/contact" class="btn btn-outline" style="border-color: rgba(255,0,204,0.4); color: var(--accent-magenta);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Get in Touch
      </a>
    </div>

    <!-- Interest badges -->
    <div class="hero-badges" aria-label="Interests">
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        Linux
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        3D Printing
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        3D Modeling
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Speedcubing
      </span>
      <span class="interest-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        Coding
      </span>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator" aria-hidden="true">
    <div class="scroll-line"></div>
    <span>scroll</span>
  </div>
</section>

<script>
  // Typing animation
  const phrases = [
    'write code.',
    'break things.',
    'print in 3D.',
    'solve cubes.',
    'run Arch Linux.',
    'build cool stuff.',
  ];

  const el = document.getElementById('typing-text');
  if (el) {
    let pIdx = 0, cIdx = 0, deleting = false;

    function type() {
      const phrase = phrases[pIdx];
      if (!deleting) {
        el.textContent = phrase.slice(0, ++cIdx);
        if (cIdx === phrase.length) {
          deleting = true;
          setTimeout(type, 1800);
          return;
        }
      } else {
        el.textContent = phrase.slice(0, --cIdx);
        if (cIdx === 0) {
          deleting = false;
          pIdx = (pIdx + 1) % phrases.length;
        }
      }
      setTimeout(type, deleting ? 45 : 85);
    }
    setTimeout(type, 600);
  }
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }

  /* ── 3D background ── */
  .hero-3d-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* ── Text overlay ── */
  .hero-content {
    position: relative;
    z-index: 10;
    padding: 3.5rem 2.5rem;
    max-width: 520px;
    pointer-events: none; /* let clicks pass through to canvas */
  }
  /* Re-enable pointer events on interactive children */
  .hero-content a,
  .hero-content button {
    pointer-events: auto;
  }

  /* Frosted glass card behind text */
  .hero-content::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
      rgba(10, 10, 20, 0.75) 0%,
      rgba(10, 10, 20, 0.55) 60%,
      transparent 100%);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border-radius: 0 24px 24px 0;
    z-index: -1;
  }

  /* Terminal prompt */
  .hero-prompt {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    padding: 0.3rem 0.75rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    margin-bottom: 1.5rem;
    white-space: nowrap;
  }
  .prompt-prefix { color: #39ff14; }
  .prompt-path   { color: rgba(255,255,255,0.4); }
  .prompt-cmd    { color: rgba(255,255,255,0.7); }

  /* Title */
  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
  }
  .hero-greeting {
    font-size: 0.45em;
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.05em;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
  }
  .hero-name {
    display: block;
    line-height: 1;
  }

  /* Subtitle / typing */
  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 1rem;
    font-family: var(--font-mono, monospace);
    min-height: 1.6em;
  }
  .typing-cursor {
    display: inline-block;
    color: var(--accent-cyan, #00e5ff);
    animation: blink-cursor 0.9s step-end infinite;
  }
  @keyframes blink-cursor { 50% { opacity: 0; } }

  /* Description */
  .hero-desc {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-bottom: 1.75rem;
    max-width: 400px;
  }
  .hero-desc em {
    color: rgba(0, 229, 255, 0.7);
    font-style: normal;
    font-family: var(--font-mono, monospace);
    font-size: 0.85em;
  }

  /* CTA buttons */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
  }

  /* Badges */
  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .interest-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.45);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
    transition: all 0.2s;
  }
  .interest-badge:hover {
    color: var(--accent-cyan, #00e5ff);
    border-color: rgba(0,229,255,0.25);
    pointer-events: auto;
  }

  /* Gradient text utility (in case var not available) */
  .gradient-text {
    background: linear-gradient(90deg, #00e5ff, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 10;
    pointer-events: none;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }
  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 0.7; transform: scaleY(0.8); }
  }
  .scroll-indicator span {
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.25);
    text-transform: uppercase;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .hero-content {
      padding: 2rem 1.25rem;
      max-width: 100%;
    }
    .hero-content::before {
      border-radius: 0;
    }
  }
</style>
