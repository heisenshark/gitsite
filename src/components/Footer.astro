---
// Footer.astro
const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/heisenshark',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/heisenshark',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Twitter/X',
    href: 'https://x.com/heisenshark',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow"></div>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span style="color: var(--accent-cyan);">[</span>
          <span class="gradient-text">heisenshark</span>
          <span style="color: var(--accent-magenta);">_</span>
          <span style="color: var(--accent-cyan);">]</span>
        </a>
        <p class="footer-tagline">
          Coder. Maker. Cube Solver. Tux enthusiast.
        </p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <span class="footer-col-title">Navigate</span>
          <a href="/">Home</a>
          <a href="/projects">Projects</a>
          <a href="/blog">Blog</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Interests</span>
          <span>3D Printing</span>
          <span>3D Modeling</span>
          <span>Speedcubing</span>
          <span>Linux & FOSS</span>
        </div>
      </div>

      <div class="footer-socials">
        <span class="footer-col-title">Find me</span>
        <div class="social-links">
          {socials.map(s => (
            <a
              href={s.href}
              class="social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              title={s.label}
              set:html={s.icon}
            />
          ))}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="text-muted text-mono" style="font-size:0.8rem;">
        &copy; {year} heisenshark — Built with <span class="gradient-text" style="font-weight:700;">Astro</span> &amp; ❤️
      </span>
      <span class="text-muted" style="font-size:0.8rem;">
        <code style="font-size:0.75rem;">rm -rf boring-websites</code>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-16) var(--space-4) var(--space-8);
    overflow: hidden;
  }

  .footer-glow {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -60%);
    width: 600px;
    height: 200px;
    background: radial-gradient(ellipse, rgba(0, 229, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    display: block;
    margin-bottom: var(--space-3);
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-cyan);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .footer-col a,
  .footer-col span {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--text-secondary);
  }

  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    color: var(--text-muted);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .social-link:hover {
    color: var(--accent-cyan);
    border-color: var(--border-accent);
    background: rgba(0, 229, 255, 0.08);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 229, 255, 0.2);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
